{
  "rules_version": "1.0",
  "description": "Automated code integrity validation rules",
  "rules": [
    {
      "rule_id": "RULE-001",
      "name": "EC Register Integrity",
      "severity": "CRITICAL",
      "description": "Every Gen9Registers entry must have RegisterSafetyRanges (except read-only)",
      "validation_method": "count_comparison",
      "file": "LenovoLegionToolkit.Lib/Controllers/Gen9ECController.cs",
      "checks": [
        {
          "check": "Gen9Registers count",
          "expected_value": 40,
          "tolerance": 0,
          "pattern": "^\\s*\\[\"[A-Z_0-9]+\"\\]\\s*=\\s*0x[0-9A-F]{2}"
        },
        {
          "check": "RegisterSafetyRanges count",
          "expected_value": 58,
          "tolerance": 0,
          "pattern": "\\(0x[0-9A-F]{2},.*0x[0-9A-F]{2}\\)"
        },
        {
          "check": "No register collisions",
          "method": "duplicate_detection",
          "alert_if": "duplicate_register_address_found"
        }
      ],
      "on_failure": {
        "action": "ALERT_AND_STOP",
        "message": "⚠️ EC register corruption detected. Register count or safety ranges invalid.",
        "suggest_rollback": true
      }
    },
    {
      "rule_id": "RULE-002",
      "name": "IoC Service Registration Completeness",
      "severity": "CRITICAL",
      "description": "All critical services must be registered in IoCModule.Load()",
      "validation_method": "service_count",
      "file": "LenovoLegionToolkit.Lib/IoCModule.cs",
      "checks": [
        {
          "check": "Total services registered",
          "expected_minimum": 8,
          "pattern": "builder\\.RegisterType<.*Services\\..*>\\(\\)"
        },
        {
          "check": "OrchestratorIntegration.RegisterServices called",
          "expected": true,
          "pattern": "AI\\.OrchestratorIntegration\\.RegisterServices\\(builder\\)"
        },
        {
          "check": "Critical services present",
          "required_services": [
            "SafeGPUPStateManager",
            "CStateManager",
            "AdaptiveRefreshRateManager",
            "WiFiPowerSaveManager",
            "RefreshRateOptimizer",
            "CPUThrottleDetector",
            "DirectECBatteryService",
            "PStateTransitionTelemetry"
          ]
        }
      ],
      "on_failure": {
        "action": "ALERT_AND_STOP",
        "message": "⚠️ IoC service registration incomplete. Missing critical services.",
        "suggest_rollback": true
      }
    },
    {
      "rule_id": "RULE-003",
      "name": "Multi-Agent Integration Points",
      "severity": "HIGH",
      "description": "PowerAgent must have 4 P-state integration points",
      "validation_method": "pattern_count",
      "file": "LenovoLegionToolkit.Lib/AI/PowerAgent.cs",
      "checks": [
        {
          "check": "P-state integration points",
          "expected_value": 4,
          "tolerance": 0,
          "pattern": "GPU_PSTATE_SAFE|SetTargetPStateAsync"
        },
        {
          "check": "Integration points at expected lines",
          "locations": [
            {"line_approx": 531, "scenario": "Media playback P8"},
            {"line_approx": 179, "scenario": "Battery critical P8/P5"},
            {"line_approx": 297, "scenario": "Battery preservation P5"},
            {"line_approx": 394, "scenario": "Gaming P0 forcing"}
          ]
        }
      ],
      "on_failure": {
        "action": "ALERT",
        "message": "⚠️ PowerAgent P-state integration points missing or modified.",
        "suggest_rollback": false
      }
    },
    {
      "rule_id": "RULE-004",
      "name": "Build Integrity",
      "severity": "CRITICAL",
      "description": "Build must succeed with 0 errors",
      "validation_method": "build_check",
      "command": "dotnet build LenovoLegionToolkit.Lib/LenovoLegionToolkit.Lib.csproj -c Release --nologo",
      "checks": [
        {
          "check": "Compilation errors",
          "expected_value": 0,
          "tolerance": 0
        },
        {
          "check": "Warnings",
          "expected_maximum": 27,
          "note": "27 nullable reference warnings are acceptable"
        }
      ],
      "on_failure": {
        "action": "ALERT_AND_STOP",
        "message": "⚠️ Build failed. Code changes introduced compilation errors.",
        "suggest_rollback": true
      }
    },
    {
      "rule_id": "RULE-005",
      "name": "Action Handler Registry",
      "severity": "HIGH",
      "description": "All 7 agents must have corresponding action handlers",
      "validation_method": "handler_count",
      "file": "LenovoLegionToolkit.Lib/AI/ActionHandlers.cs",
      "checks": [
        {
          "check": "Total action handlers",
          "expected_value": 7,
          "tolerance": 0,
          "pattern": "class \\w+Handler\\s*:\\s*IActionHandler"
        },
        {
          "check": "Required handlers present",
          "required_handlers": [
            "ThermalActionHandler",
            "SafeGPUPStateHandler",
            "GPUActionHandler",
            "BatteryActionHandler",
            "HybridModeActionHandler",
            "DisplayActionHandler",
            "KeyboardLightActionHandler"
          ]
        }
      ],
      "on_failure": {
        "action": "ALERT",
        "message": "⚠️ Action handler missing or orphaned agent detected.",
        "suggest_rollback": false
      }
    }
  ],
  "validation_schedule": {
    "session_start": ["RULE-001", "RULE-002", "RULE-003", "RULE-004", "RULE-005"],
    "before_major_change": ["RULE-001", "RULE-002", "RULE-004"],
    "after_code_change": ["RULE-004"],
    "periodic_15min": ["RULE-004"]
  }
}
