{
  "policy_version": "1.0",
  "enabled": true,
  "description": "Periodic context snapshots to prevent data loss",
  "snapshot_interval_minutes": 5,
  "snapshot_targets": [
    {
      "target": "agent_states",
      "frequency": "every_interval",
      "destination": ".context/agents/state_snapshots/",
      "format": "agent_{name}_state_{timestamp}.json",
      "retention_count": 20,
      "agents": [
        "ThermalAgent",
        "PowerAgent",
        "GPUAgent",
        "BatteryAgent",
        "HybridModeAgent",
        "DisplayAgent",
        "KeyboardLightAgent"
      ]
    },
    {
      "target": "session_state",
      "frequency": "every_interval",
      "destination": ".context/sessions/active/",
      "format": "session_state.json",
      "overwrite": true
    },
    {
      "target": "task_log",
      "frequency": "on_task_complete",
      "destination": ".context/sessions/active/",
      "format": "task_log.jsonl",
      "append_only": true
    },
    {
      "target": "code_changes",
      "frequency": "on_file_modify",
      "destination": ".context/sessions/active/",
      "format": "code_changes.jsonl",
      "append_only": true,
      "tracked_files": [
        "LenovoLegionToolkit.Lib/IoCModule.cs",
        "LenovoLegionToolkit.Lib/Controllers/Gen9ECController.cs",
        "LenovoLegionToolkit.Lib/Services/SafeGPUPStateManager.cs",
        "LenovoLegionToolkit.Lib/AI/ActionHandlers.cs",
        "LenovoLegionToolkit.Lib/AI/PowerAgent.cs",
        "LenovoLegionToolkit.Lib/AI/ThermalOptimizer.cs",
        "LenovoLegionToolkit.Lib/AI/OrchestratorIntegration.cs"
      ]
    }
  ],
  "cleanup_policy": {
    "enabled": true,
    "delete_snapshots_older_than_days": 7,
    "archive_to": ".context/sessions/archive/"
  }
}
