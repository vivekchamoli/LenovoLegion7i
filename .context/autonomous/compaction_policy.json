{
  "policy_version": "1.0",
  "enabled": true,
  "description": "Context compaction policy to prevent unbounded growth",
  "triggers": [
    {
      "type": "session_end",
      "action": "compact_and_archive",
      "condition": "session_duration > 2 hours OR tasks_completed > 5"
    },
    {
      "type": "file_size_threshold",
      "action": "compact_current_session",
      "condition": "session_state.json > 100KB OR task_log.jsonl > 500KB"
    },
    {
      "type": "scheduled",
      "action": "cleanup_old_archives",
      "frequency": "daily",
      "keep_last_sessions": 10
    }
  ],
  "compaction_rules": {
    "tasks": {
      "keep_all_critical_bugs": true,
      "keep_all_p0_tasks": true,
      "summarize_p2_p3_tasks": true,
      "summary_format": "{task_count} tasks completed ({p0_count} P0, {p1_count} P1)"
    },
    "code_changes": {
      "keep_all_critical_file_changes": true,
      "keep_purpose_and_impact": true,
      "discard_intermediate_states": true,
      "critical_files": [
        "IoCModule.cs",
        "Gen9ECController.cs",
        "SafeGPUPStateManager.cs",
        "ActionHandlers.cs",
        "PowerAgent.cs"
      ]
    },
    "agent_states": {
      "keep_latest_only": true,
      "keep_state_changes": true,
      "discard_duplicate_states": true
    },
    "lessons_learned": {
      "keep_all": true,
      "deduplicate": true,
      "merge_similar": true
    }
  },
  "archive_format": {
    "type": "json",
    "compression": "none",
    "filename_pattern": "{session_date}_summary.json",
    "destination": ".context/sessions/archive/"
  }
}
