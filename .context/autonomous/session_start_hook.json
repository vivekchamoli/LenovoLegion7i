{
  "hook_version": "1.0",
  "enabled": true,
  "description": "Autonomous validation and context loading at session start",
  "execution_order": [
    {
      "step": 1,
      "action": "load_last_session_summary",
      "source": ".context/memory/session_summaries.json",
      "purpose": "Resume with full knowledge of previous work"
    },
    {
      "step": 2,
      "action": "validate_file_checksums",
      "source": ".context/checkpoints/file_checksums/",
      "critical_files": [
        "LenovoLegionToolkit.Lib/IoCModule.cs",
        "LenovoLegionToolkit.Lib/Controllers/Gen9ECController.cs",
        "LenovoLegionToolkit.Lib/Services/SafeGPUPStateManager.cs",
        "LenovoLegionToolkit.Lib/AI/ActionHandlers.cs",
        "LenovoLegionToolkit.Lib/AI/PowerAgent.cs"
      ],
      "on_mismatch": "ALERT_AND_STOP"
    },
    {
      "step": 3,
      "action": "load_agent_states",
      "source": ".context/agents/state_snapshots/",
      "purpose": "Restore exact agent operational state"
    },
    {
      "step": 4,
      "action": "validate_code_integrity",
      "checks": [
        "ec_register_count_40",
        "safety_ranges_count_58",
        "ioc_services_count_8",
        "action_handlers_count_7",
        "pstate_integration_points_4"
      ],
      "on_failure": "ALERT_WITH_DETAILS"
    },
    {
      "step": 5,
      "action": "report_validation_results",
      "format": "concise_summary",
      "include": ["last_session_summary", "validation_status", "agent_states"]
    }
  ],
  "auto_fix_enabled": false,
  "alert_severity": "HIGH",
  "execution_time_budget_ms": 5000
}
